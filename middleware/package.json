{
  "name": "iot-blockchain-middleware",
  "version": "1.0.0",
  "description": "Middleware Node.js per ricevere misurazioni firmate da ESP32 e registrarle su smart contract.",
  "type": "module",
  "private": true,
  "scripts": {
    "start:anvil": "DOTENV_CONFIG_PATH=.env.anvil node -r dotenv/config server.js",
    "dev:anvil": "DOTENV_CONFIG_PATH=.env.anvil node -r dotenv/config --watch server.js",
    "start:sepolia": "DOTENV_CONFIG_PATH=.env.sepolia node -r dotenv/config server.js",
    "dev:sepolia": "DOTENV_CONFIG_PATH=.env.sepolia node -r dotenv/config --watch server.js",
    "simulate-device:anvil": "DOTENV_CONFIG_PATH=.env.anvil node -r dotenv/config scripts/simulate-device.js",
    "simulate-device:sepolia": "DOTENV_CONFIG_PATH=.env.sepolia node -r dotenv/config scripts/simulate-device.js",
    "simulate-buffered:anvil": "DOTENV_CONFIG_PATH=.env.anvil node -r dotenv/config scripts/simulate-buffered-measurements.js",
    "simulate-buffered:sepolia": "DOTENV_CONFIG_PATH=.env.sepolia node -r dotenv/config scripts/simulate-buffered-measurements.js",
    "register-device:anvil": "DOTENV_CONFIG_PATH=.env.anvil node -r dotenv/config scripts/register-device.js",
    "register-device:sepolia": "DOTENV_CONFIG_PATH=.env.sepolia node -r dotenv/config scripts/register-device.js",
    "test-negative-measurements:anvil": "DOTENV_CONFIG_PATH=.env.anvil node -r dotenv/config scripts/test-negative-measurements.js",
    "test-negative-measurements:sepolia": "DOTENV_CONFIG_PATH=.env.sepolia node -r dotenv/config scripts/test-negative-measurements.js",
    "verify-hash:anvil": "DOTENV_CONFIG_PATH=.env.anvil node -r dotenv/config scripts/verify-hash-consistency.js",
    "verify-hash:sepolia": "DOTENV_CONFIG_PATH=.env.sepolia node -r dotenv/config scripts/verify-hash-consistency.js"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "ethers": "^6.15.0",
    "express": "^5.1.0"
  }
}